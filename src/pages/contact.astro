---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contacto',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="Contacto" title="¡Conversemos!" />

  <ContactUs
    id="form"
    title="Cuéntanos de tu proyecto"
    subtitle="Escríbenos y te responderemos a la brevedad. Cuéntanos qué espacio quieres digitalizar y te ayudaremos a encontrar la mejor solución."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Nombre',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Correo electrónico',
      },
    ]}
    textarea={{
      label: 'Mensaje',
    }}
    disclaimer={{
      label:
        'Al enviar este formulario, aceptas que utilicemos tus datos de contacto para responder a tu consulta, según nuestra Política de Privacidad.',
    }}
    button="Enviar mensaje"
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="¡Estamos aquí para ayudarte!"
    items={[
      {
        title: 'Cotizaciones',
        description: `Escríbenos para cotizar tu tour virtual 360°, publicación en Google Street View, modelado 3D, gemelo digital o captura 4D. Cada proyecto se evalúa según el tamaño y las características del espacio.`,
      },
      {
        title: 'Consultas generales',
        description:
          'Si tienes dudas sobre cómo funcionan nuestros servicios, en qué industrias aplican o qué necesitas para comenzar, contáctanos y te orientamos sin compromiso.',
      },
      {
        title: 'Soporte',
        description:
          '¿Ya eres cliente y necesitas ayuda con tu tour virtual, tu publicación en Street View o algún entregable? Escríbenos y lo resolvemos a la brevedad.',
      },
      {
        title: 'WhatsApp',
        description: `<a href="https://wa.me/56930679681?text=Hola%2C%20quiero%20cotizar%20un%20tour%20virtual" target="_blank" rel="noopener" class="hover:underline">+56 9 3067 9681</a>`,
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Email',
        description: 'contacto@4dvista.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Instagram',
        description: '@4dvista',
        icon: 'tabler:brand-instagram',
      },
    ]}
  />
</Layout>
